# Configuración de Hugging Face Spaces
PORT=7860
NODE_ENV=production

# MongoDB Atlas - IMPORTANTE: Reemplaza con tu URI
# Formato: mongodb+srv://usuario:contraseña@cluster.mongodb.net/nombreBaseDatos?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://usuario:contraseña@tu-cluster.mongodb.net/maxiqueen?retryWrites=true&w=majority

# Alternativa (si usas MONGODB_URI en lugar de MONGO_URI)
# MONGODB_URI=mongodb+srv://usuario:contraseña@tu-cluster.mongodb.net/maxiqueen?retryWrites=true&w=majority

